# Get these from your Moyasar dashboard: https://dashboard.moyasar.com/
# Never commit the real .env file or share your secret key publicly.

MOYASAR_SECRET_KEY=YOUR_MOYASAR_SECRET_KEY_HERE
MOYASAR_PUBLISHABLE_KEY=YOUR_MOYASAR_PUBLISHABLE_KEY_HERE

# Set this in Moyasar's dashboard webhook config too — used to verify
# that webhook requests really came from Moyasar.
MOYASAR_WEBHOOK_SECRET=change-this-to-a-long-random-string

# Where Moyasar redirects the shopper's browser after 3-D Secure
CALLBACK_URL=http://localhost:4000/api/payments/callback

# Your actual frontend origin (checkout.jsx). Used for CORS and for
# building the final redirect back to your checkout page.
FRONTEND_URL=http://localhost:5173

# Protects GET /api/admin/payments — pick a long random string
ADMIN_API_KEY=change-this-to-a-long-random-string

# Where the SQLite database file is stored
DB_PATH=./data/payments.db

PORT=4000
NODE_ENV=development
