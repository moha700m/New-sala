# /etc/nginx/sites-available/agent-souq-api
#
# Reverse proxy: public HTTPS traffic → local Node process on :4000
# After copying this in, run:
#   sudo ln -s /etc/nginx/sites-available/agent-souq-api /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d api.your-domain.com

server {
    listen 80;
    server_name api.your-domain.com;

    # Apple Pay domain verification file must be reachable over plain HTTP/HTTPS
    # at exactly this path — Express already serves it from public/.well-known/
    location /.well-known/apple-developer-merchantid-domain-association {
        proxy_pass http://127.0.0.1:4000;
    }

    location / {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
